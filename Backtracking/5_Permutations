          /            \
       pick 1         pick 2
      ds=[1]         ds=[2]
     set={1}        set={2}
      /                \
  pick 2             pick 1
 ds=[1,2]          ds=[2,1]
 set={1,2}         set={2,1}
    |                 |
  add to res       add to res
