class Solution {
public:
    int characterReplacement(string s, int k) 
    {
        int maxlen=0;
        int n=s.length();       

        for(int i=0;i<n;i++)
        {
            unordered_map<char,int> mpp;
            int maxfreq=0;//imp
            for(int j=i;j<n;j++)
            {
                 mpp[s[j]]++;
                 maxfreq = max(maxfreq,mpp[s[j]]);

                 if(j-i+1-maxfreq <=k)
                 {
                    maxlen = max(maxlen,j-i+1);
                 }
            }
        }
        return maxlen;
    }
};

