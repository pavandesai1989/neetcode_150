***sliding window***
class Solution {
public:
    int characterReplacement(string s, int k) 
    {
        int maxlen=0;
        int n=s.length();  
        int i=0,j=0;
        int maxfreq=0;
        unordered_map<char,int> mpp;

        while(j<n)
        {
           //add to map
           mpp[s[j]]++;

           maxfreq= max(maxfreq,mpp[s[j]]);
           if((j-i+1 - maxfreq) >k)
           {
              mpp[s[i]]--;

              if(mpp[s[i]]==0)
              {
                mpp.erase(s[i]);
              }
              i++;
           }

           maxlen = max(maxlen,j-i+1);

           j++;        
        }     
        return maxlen;        
    }
};

